<Window
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
x:Class="AudioPlayer.AvaloniaApp.PlayerWindow"
xmlns:tags="clr-namespace:AudioPlayer.Tags"
Title="ZPlayer"
CanMaximize="True"
Width="920"
MinWidth="920"
MinHeight="620"
Height="920"
SystemDecorations="None"
TransparencyLevelHint="Transparent"
Background="Transparent"
CanResize="True"
WindowStartupLocation="CenterScreen"
>


	<Border CornerRadius="20"
        Background="#2D2D2D"
        ClipToBounds="True">
		<Grid>
			<Border Name="TitleBar"
					Background="Transparent"
					Height="40"
					VerticalAlignment="Top">

				<TextBlock Text="ZPlayer"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>
			</Border>

			<Image Name="BackgroundImage"
				   Stretch="UniformToFill"
				   IsHitTestVisible="False"
				   HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   Opacity="0.6">
				<Image.Effect>
					<BlurEffect Radius="100" />
				</Image.Effect>
			</Image>

			<Grid RowDefinitions="*" ColumnDefinitions="*, 450" Margin="10,10,10,10">

				<Grid
				Grid.Column="0"
				RowDefinitions="*,Auto,Auto,Auto"
				ColumnDefinitions="*">

					<!-- Обложка -->
					<Grid Width="450" Height="450">

						<Viewbox Stretch="Uniform" Margin="40">
							<PathIcon
							Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12.5,7V12.25C12.5,13.22 11.72,14 10.75,14C9.78,14 9,13.22 9,12.25C9,11.28 9.78,10.5 10.75,10.5C11.14,10.5 11.5,10.63 11.78,10.84V7H12.5Z"
							Foreground="#444444" />
						</Viewbox>

						<Border CornerRadius="15"
								BoxShadow="0 10 35 5 #FF000000"
								VerticalAlignment="Center"
								Margin="20,40,20,20">

							<Border CornerRadius="15"
									ClipToBounds="True">
								<Image Name="AlbumArt" Stretch="UniformToFill" />
							</Border>
						</Border>
					</Grid>
					<!-- ======= -->

					<StackPanel Grid.Row="1" Margin="10,10" Spacing="2.5">
						<TextBlock Name="Title_Txt" Text="Title" TextTrimming="CharacterEllipsis" FontWeight="Bold" FontSize="18" HorizontalAlignment="Left" Margin="0,0,0,0"/>
						<TextBlock Name="Artist_Txt" Text="Artist" TextTrimming="CharacterEllipsis" FontSize="13" HorizontalAlignment="Left" Margin="0"/>
					</StackPanel>

					<!-- Прогресс -->
					<Slider
					Grid.Row="2"
					Margin="10,10"
					Name="ProgressSlider">
					</Slider>
					<!-- ======= -->

					<StackPanel Grid.Column="0" Grid.Row="3" Orientation="Horizontal"
								HorizontalAlignment="Center" Spacing="10">

						<Button Name="PrevBtn" Click="Prev" Background="Transparent"
								CornerRadius="20">
							<PathIcon Data="M18,6L9.5,12L18,18V6M8,18V6H6V18H8Z"
									  Foreground="White" Width="25" Height="25" />
						</Button>

						<Button Name="PlayBtn" Click="Play" Background="Transparent"
								CornerRadius="20">
							<PathIcon Data="M6,19L19,12L6,5V19Z" Foreground="White" Width="25"
									  Height="25" />
						</Button>

						<Button Name="NextBtn" Background="Transparent" Click="Next"
								CornerRadius="20">
							<PathIcon Data="M6,18L14.5,12L6,6V18M16,6V18H18V6H16Z"
									  Foreground="White" Width="25" Height="25" />
						</Button>
						<Slider Name="VolumeSlider" Value="100"
								Foreground="White" Background="White"
								ValueChanged="SetVolume" Width="100"
								HorizontalAlignment="Right" />
					</StackPanel>
				</Grid>

				<Grid Grid.Column="1" Margin="20,20,20,20" Background="Transparent" RowDefinitions="*,Auto">
					<ListBox Name="playlist"
							 Background="#44000000"
							 Padding="10"
							 CornerRadius="5"
							 Grid.Row="0"
							 DoubleTapped="OnUserDoubleTapToTrack">


						<ListBox.Styles>
							<Style Selector="ListBox">

							</Style>

							<Style Selector="ListBoxItem">
								<Setter Property="Background" Value="#44000000" />
								<Setter Property="CornerRadius" Value="8" />
								<Setter Property="Padding" Value="12,8" />
								<Setter Property="Margin" Value="4,2" />
							</Style>

							<Style
							Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
								<Setter Property="Background" Value="#3B2A2A2A" />
							</Style>

							<Style
							Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
								<Setter Property="Background" Value="#2aa2a2a2" />
							</Style>

							<Style
							Selector="ListBoxItem:selected:not(:focus) /template/ ContentPresenter#PART_ContentPresenter">
								<Setter Property="Background" Value="#ff4e4e4e" />
							</Style>

						</ListBox.Styles>

						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="tags:TrackMinimalMetadata">
								<Grid ColumnDefinitions="Auto,*, Auto" Margin="5">
									<Border Grid.Column="0" Width="42" Height="42" ClipToBounds="true" CornerRadius="8" Margin="0,0,30,0">
										<Image Source="{Binding CoverImage}" />
									</Border>
									<StackPanel Grid.Column="1" VerticalAlignment="Center"
                                            >
										<TextBlock Text="{Binding TrackDisplay}" FontWeight="SemiBold"
												   TextTrimming="CharacterEllipsis" Foreground="White"
												   Margin="0,0,10,0" />
										<TextBlock Text="{Binding ArtistDisplay}" FontSize="12"
												   TextTrimming="CharacterEllipsis" Foreground="Gray" />
									</StackPanel>
									<TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
											   Foreground="Gray" VerticalAlignment="Center" />
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<StackPanel Grid.Row="0" VerticalAlignment="Bottom" Margin="0,10" Background="Transparent">
						<Button Name="AddFileBtn" Background="Transparent" Click="SelectFiles"
								CornerRadius="20">
							<PathIcon
							Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
							Foreground="White" Width="25" Height="25" />
						</Button>
					</StackPanel>

				</Grid>

			</Grid>
		</Grid>
	</Border>
</Window>